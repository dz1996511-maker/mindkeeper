# ── 必填 ──────────────────────────────────────────────────
ASTRBOT_PASS=请修改为强密码

# ── WebUI (可选, 默认值如下) ──────────────────────────────
ASTRBOT_USER=admin
ASTRBOT_WEBUI_PORT=6185

# ── LLM Provider: Claude (可选, 也可以在 WebUI 中配置) ────
# CLAUDE_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ── LLM Provider: DeepSeek (可选, 价格更低) ────────────────
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat

# ── 平台: 钉钉 (可选) ─────────────────────────────────────
# DINGTALK_APP_KEY=...
# DINGTALK_APP_SECRET=...

# ── 平台: 飞书 (可选) ─────────────────────────────────────
# FEISHU_APP_ID=...
# FEISHU_APP_SECRET=...

# ── 平台: 微信 (通过 Gewechat, 可选) ──────────────────────
# WECHAT_WEBHOOK_PORT=11451

# ── 时区 ───────────────────────────────────────────────────
TZ=Asia/Shanghai
